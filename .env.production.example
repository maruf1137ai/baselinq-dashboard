# Production env for frontend build. Copy to .env.production and set values.
# Used when running: npm run build (or by deploy script).

# Required: your deployed backend API base URL (no trailing slash; frontend adds /api/)
VITE_API_BASE_URL=https://your-backend.railway.app/api

# Optional: Supabase (if you use it in production)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
